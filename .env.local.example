# Prism — environment variables
#
# Copy this file to `.env.local` (which is git-ignored) and fill in your key.
#
# Groq powers the sentence classifier + the fact-check judge
# (model: llama-3.3-70b-versatile).
# Create a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Tavily powers the fact-checker's web search (finds real sources per claim).
# Create a free key at https://app.tavily.com  (1,000 searches/month free).
# Only needed for the Fact Check section; the rest of the app works without it.
TAVILY_API_KEY=

# ── Public-deployment hardening (all OPTIONAL) ─────────────────────────────
# Without these, Prism runs exactly as before: no caching, no rate limiting.
#
# Upstash Redis powers BOTH response caching (repeat tests cost nothing) and the
# per-visitor rate limit that protects your Groq/Tavily quota from abuse. Free
# tier at https://upstash.com — or add a Redis integration on Vercel (Storage →
# Marketplace), which injects the vars automatically. The code reads EITHER the
# UPSTASH_REDIS_REST_* names below OR Vercel KV's KV_REST_API_URL/KV_REST_API_TOKEN,
# so whichever integration you pick works — but they MUST exist in the deployed
# environment, and env-var changes only take effect after a REDEPLOY.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# A secret only YOU hold. Visit /get-started?key=<this value> once to drop a
# cookie that skips the rate limit — so you can always demo, even when the
# public is throttled. Leave blank to disable the bypass.
OWNER_BYPASS_KEY=

# Requests allowed per visitor (IP) per hour across all analysis routes. A full
# five-screen run is ~5 requests. Defaults to 30 when unset.
RATE_LIMIT_PER_HOUR=30
