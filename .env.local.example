# Prism — environment variables
#
# Copy this file to `.env.local` (which is git-ignored) and fill in your key.
#
# Groq powers the sentence classifier + the fact-check judge
# (model: llama-3.3-70b-versatile).
# Create a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Tavily powers the fact-checker's web search (finds real sources per claim).
# Create a free key at https://app.tavily.com  (1,000 searches/month free).
# Only needed for the Fact Check section; the rest of the app works without it.
TAVILY_API_KEY=
